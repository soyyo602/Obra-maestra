<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0047AB" />
  <title>Obra Maestra</title>
  <link rel="manifest" href="manifest.json" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --azul: #0047AB;
      --azul-oscuro: #00338A;
      --amarillo: #FFD700;
      --amarillo-suave: #FFF3A3;
      --blanco: #FFFFFF;
      --gris: #2D2D2D;
      --gris-suave: #F2F4F8;
      --gris-borde: #D0D7E8;
    }
    html, body { height: 100%; font-family: 'Inter', sans-serif; background: var(--gris-suave); color: var(--gris); }
    header { background: var(--azul); padding: 20px 24px 18px; display: flex; align-items: center; gap: 14px; box-shadow: 0 3px 12px rgba(0,71,171,0.25); }
    .logo { width: 46px; height: 46px; flex-shrink: 0; }
    .header-text h1 { font-family: 'Montserrat', sans-serif; font-weight: 900; font-size: 1.55rem; color: var(--amarillo); letter-spacing: 0.5px; line-height: 1; }
    .header-text p { font-size: 0.72rem; color: rgba(255,255,255,0.75); letter-spacing: 1.5px; text-transform: uppercase; margin-top: 3px; }
    .user-bar { background: var(--azul-oscuro); padding: 8px 24px; display: flex; align-items: center; justify-content: space-between; }
    .user-bar span { font-size: 0.78rem; color: rgba(255,255,255,0.8); }
    .user-bar strong { color: var(--amarillo); font-weight: 600; }
    .user-dot { width: 8px; height: 8px; background: #4ADE80; border-radius: 50%; display: inline-block; margin-right: 6px; animation: pulso 2s infinite; }
    @keyframes pulso { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    main { padding: 20px 16px 32px; max-width: 600px; margin: 0 auto; }
    .seccion-titulo { font-size: 0.7rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--azul); margin: 24px 0 10px; border-left: 3px solid var(--amarillo); padding-left: 8px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .grid.ancho { grid-template-columns: 1fr; }
    .tarjeta { background: var(--blanco); border-radius: 14px; padding: 18px 16px; display: flex; flex-direction: column; align-items: flex-start; gap: 8px; border: 1.5px solid var(--gris-borde); cursor: pointer; text-decoration: none; color: var(--gris); transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s; position: relative; overflow: hidden; }
    .tarjeta:active { transform: scale(0.97); }
    .tarjeta:hover { border-color: var(--azul); box-shadow: 0 6px 20px rgba(0,71,171,0.12); }
    .tarjeta.principal { border-color: var(--azul); background: linear-gradient(135deg, #EEF3FF 0%, #ffffff 100%); }
    .tarjeta.bloqueada { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
    .tarjeta-icono { width: 36px; height: 36px; background: var(--azul); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .tarjeta-icono svg { width: 20px; height: 20px; fill: none; stroke: var(--amarillo); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .tarjeta.bloqueada .tarjeta-icono { background: #9CA3AF; }
    .tarjeta.bloqueada .tarjeta-icono svg { stroke: #ffffff; }
    .tarjeta-nombre { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.9rem; color: var(--azul); line-height: 1.2; }
    .tarjeta.bloqueada .tarjeta-nombre { color: #6B7280; }
    .tarjeta-desc { font-size: 0.72rem; color: #6B7280; line-height: 1.4; }
    .badge { position: absolute; top: 10px; right: 10px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.5px; padding: 2px 7px; border-radius: 20px; text-transform: uppercase; }
    .badge.activo { background: #DCFCE7; color: #166534; }
    .badge.pronto { background: var(--amarillo-suave); color: #92400E; }
    .badge.restringido { background: #FEE2E2; color: #991B1B; }
    footer { text-align: center; padding: 24px 16px; font-size: 0.68rem; color: #9CA3AF; letter-spacing: 0.5px; }
    footer strong { color: var(--azul); }
    @media (max-width: 360px) { .grid { grid-template-columns: 1fr; } .header-text h1 { font-size: 1.3rem; } }
  </style>
</head>
<body>
  <header>
    <svg class="logo" viewBox="0 0 46 46" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="23" cy="23" r="23" fill="#FFD700"/>
      <line x1="23" y1="8" x2="23" y2="32" stroke="#0047AB" stroke-width="2.5" stroke-linecap="round"/>
      <polygon points="23,36 19,28 27,28" fill="#0047AB"/>
      <line x1="10" y1="20" x2="36" y2="20" stroke="#0047AB" stroke-width="2" stroke-linecap="round"/>
      <circle cx="23" cy="20" r="3" fill="#0047AB"/>
    </svg>
    <div class="header-text">
      <h1>OBRA MAESTRA</h1>
      <p>Gamboa Construcciones · Merida, Yucatan</p>
    </div>
  </header>

  <div class="user-bar">
    <span><span class="user-dot"></span>Sesion activa: <strong>Pedro Felipe Gamboa</strong></span>
    <span style="font-size:0.7rem; color:rgba(255,255,255,0.5);">Director Tecnico</span>
  </div>

  <main>

    <div class="seccion-titulo">Campo</div>
    <div class="grid">

      <a href="#" class="tarjeta principal">
        <span class="badge activo">Activo</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div class="tarjeta-nombre">Obra Facil</div>
        <div class="tarjeta-desc">Avance diario, materiales y control de campo</div>
      </a>

      <a href="#" class="tarjeta principal">
        <span class="badge activo">Activo</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <div class="tarjeta-nombre">Levantamiento de Obra</div>
        <div class="tarjeta-desc">Mediciones y registro de cantidades en campo</div>
      </a>

      <a href="#" class="tarjeta principal">
        <span class="badge activo">Activo</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="tarjeta-nombre">Guia de Obra</div>
        <div class="tarjeta-desc">Ruta critica, procesos y suministros por etapa</div>
      </a>

    </div>

    <div class="seccion-titulo">Calculo Tecnico</div>
    <div class="grid">

      <a href="#" class="tarjeta principal">
        <span class="badge activo">Activo</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </div>
        <div class="tarjeta-nombre">Calcula Estructural</div>
        <div class="tarjeta-desc">Vigas, columnas, losas y cimentaciones</div>
      </a>

      <a href="#" class="tarjeta bloqueada">
        <span class="badge pronto">Pronto</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        </div>
        <div class="tarjeta-nombre">Calcula Electrico</div>
        <div class="tarjeta-desc">Instalacion electrica y cargas</div>
      </a>

      <a href="#" class="tarjeta bloqueada">
        <span class="badge pronto">Pronto</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
        </div>
        <div class="tarjeta-nombre">Calcula Acabados</div>
        <div class="tarjeta-desc">Computos y presupuesto de acabados</div>
      </a>

    </div>

    <div class="seccion-titulo">Sistemas Especiales</div>
    <div class="grid">

      <a href="#" class="tarjeta bloqueada">
        <span class="badge pronto">Pronto</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="tarjeta-nombre">Sistema Albercas</div>
        <div class="tarjeta-desc">Diseno y purificacion</div>
      </a>

      <a href="#" class="tarjeta bloqueada">
        <span class="badge pronto">Pronto</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><path d="M12 2v6m0 0C8 8 4 12 4 17h16c0-5-4-9-8-9z"/><line x1="4" y1="21" x2="20" y2="21"/></svg>
        </div>
        <div class="tarjeta-nombre">Sistema Cisternas</div>
        <div class="tarjeta-desc">Diseno y purificacion</div>
      </a>

    </div>

    <div class="seccion-titulo">Direccion</div>
    <div class="grid">

      <a href="#" class="tarjeta">
        <span class="badge restringido">Privado</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <div class="tarjeta-nombre">Bitacora de Obra</div>
        <div class="tarjeta-desc">Registro formal y decisiones tecnicas</div>
      </a>

      <a href="#" class="tarjeta">
        <span class="badge restringido">Privado</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <div class="tarjeta-nombre">Control Visual Drone</div>
        <div class="tarjeta-desc">Fotografia aerea y seguimiento de obra</div>
      </a>

    </div>

    <div class="seccion-titulo">Administracion</div>
    <div class="grid ancho">

      <a href="#" class="tarjeta">
        <span class="badge pronto">Pronto</span>
        <div class="tarjeta-icono">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <div class="tarjeta-nombre">Dashboard General</div>
        <div class="tarjeta-desc">Vista global de todos los proyectos activos, costos y avances</div>
      </a>

    </div>

  </main>

  <footer>
    <strong>OBRA MAESTRA</strong> · Ecosistema de Construccion<br/>
    Gamboa Construcciones · Merida, Yucatan · v1.0
  </footer>

  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('sw.js');
    }
  </script>
</body>
</html>
